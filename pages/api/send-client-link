import { Resend } from "resend";
import crypto from "crypto";

const resend = new Resend(process.env.RESEND_API_KEY);

export default async function handler(req, res) {
  const { email, quoteId } = req.body;

  if (!email || !quoteId) {
    return res.status(400).json({ error: "Missing data" });
  }

  // 1. generate secure token
  const token = crypto.randomBytes(24).toString("hex");

  // 2. store token in Firestore via your API
  await fetch(`${process.env.NEXT_PUBLIC_BASE_URL}/api/save-client-token`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ quoteId, token }),
  });

  // 3. build secure link
  const link = `${process.env.NEXT_PUBLIC_BASE_URL}/client/${quoteId}?token=${token}`;

  // 4. send email
  await resend.emails.send({
    from: "Estimates <onboarding@resend.dev>",
    to: email,
    subject: "Your Estimate is Ready",
    html: `
      <h2>Your Contractor Estimate</h2>
      <p>Click below to view your quote:</p>
      <a href="${link}">View Estimate</a>
    `,
  });

  res.status(200).json({ success: true });
}
